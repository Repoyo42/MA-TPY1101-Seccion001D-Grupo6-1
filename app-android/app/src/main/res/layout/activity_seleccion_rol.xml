<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1a0a2e"
    android:padding="24dp">

    <TextView
        android:text="✨"
        android:textSize="64sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:text="¡Bienvenido a ConectaTarot!"
        android:textColor="#d4aaff"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:text="¿Cómo quieres usar la app?"
        android:textColor="#9b59b6"
        android:textSize="15sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnSoyCliente"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="🔍 Quiero buscar tarotistas\n(Soy Cliente)"
        android:textColor="#ffffff"
        android:backgroundTint="#7d3cae"
        android:textSize="15sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSoyTarotista"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="🔮 Quiero ofrecer mis servicios\n(Soy Tarotista)"
        android:textColor="#ffffff"
        android:backgroundTint="#2d1654"
        android:textSize="15sp"/>

</LinearLayout>