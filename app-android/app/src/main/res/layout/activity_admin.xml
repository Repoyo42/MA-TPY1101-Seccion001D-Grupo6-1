<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a0a2e">


    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="80dp">


        <TextView

            android:id="@+id/tvTitulo"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="🔮 Panel Administrador"

            android:textColor="#d4aaff"

            android:textSize="24sp"

            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="Cerrar sesión"
            android:textColor="#ff6666"
            android:textSize="16sp"/>

        <TextView

            android:id="@+id/tvUsuarios"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="24dp"

            android:background="#2d1654"

            android:padding="16dp"

            android:text="Usuarios: 0"

            android:textColor="#d4aaff"

            android:textSize="18sp"/>



        <TextView

            android:id="@+id/tvTarotistas"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:background="#2d1654"

            android:padding="16dp"

            android:text="Tarotistas: 0"

            android:textColor="#d4aaff"

            android:textSize="18sp"/>



        <TextView

            android:id="@+id/tvPendientes"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:background="#2d1654"

            android:padding="16dp"

            android:text="Pendientes: 0"

            android:textColor="#d4aaff"

            android:textSize="18sp"/>



        <TextView

            android:id="@+id/tvSesiones"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:background="#2d1654"

            android:padding="16dp"

            android:text="Sesiones: 0"

            android:textColor="#d4aaff"

            android:textSize="18sp"/>



    </LinearLayout>



    <com.google.android.material.bottomnavigation.BottomNavigationView

        android:id="@+id/bottomNav"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:layout_gravity="bottom"

        android:background="#2d1654"

        app:itemIconTint="#d4aaff"

        app:itemTextColor="#d4aaff"

        app:menu="@menu/admin_bottom_nav_menu"/>


</androidx.coordinatorlayout.widget.CoordinatorLayout>